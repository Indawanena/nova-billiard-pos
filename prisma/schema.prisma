generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  CASHIER
  STAFF
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum SessionStatus {
  ACTIVE
  PAUSED
  CLOSED
  VOID
}

enum ProductCategory {
  FOOD
  BEVERAGE
  OTHER
}

enum OrderStatus {
  OPEN
  SENT
  SERVED
  CANCELLED
}

enum PaymentMethod {
  CASH
  QRIS
  CARD
  TRANSFER
}

enum PaymentStatus {
  PAID
  REFUNDED
  VOID
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  openedSessions TableSession[] @relation("OpenedBy")
  closedSessions TableSession[] @relation("ClosedBy")
  orders         Order[]
  payments       Payment[]
}

model BilliardTable {
  id        String      @id @default(cuid())
  code      String      @unique
  name      String
  status    TableStatus @default(AVAILABLE)
  hourlyRate Decimal    @db.Decimal(12, 2)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  sessions TableSession[]
}

model TableSession {
  id          String        @id @default(cuid())
  tableId     String
  status      SessionStatus @default(ACTIVE)
  startedAt   DateTime      @default(now())
  endedAt     DateTime?
  pausedAt    DateTime?
  totalMinutes Int          @default(0)
  tableAmount Decimal       @default(0) @db.Decimal(12, 2)
  notes       String?
  openedById  String
  closedById  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  table     BilliardTable @relation(fields: [tableId], references: [id])
  openedBy  User          @relation("OpenedBy", fields: [openedById], references: [id])
  closedBy  User?         @relation("ClosedBy", fields: [closedById], references: [id])
  orders    Order[]
  payments  Payment[]

  @@index([tableId, status])
  @@index([startedAt])
}

model Product {
  id        String          @id @default(cuid())
  sku       String?         @unique
  name      String
  category  ProductCategory
  price     Decimal         @db.Decimal(12, 2)
  stock     Int             @default(0)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  orderItems OrderItem[]
}

model Order {
  id        String      @id @default(cuid())
  sessionId String?
  userId    String
  status    OrderStatus @default(OPEN)
  subtotal  Decimal     @default(0) @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  session TableSession? @relation(fields: [sessionId], references: [id])
  user    User          @relation(fields: [userId], references: [id])
  items   OrderItem[]

  @@index([sessionId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  qty       Int
  price     Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id        String        @id @default(cuid())
  sessionId String?
  userId    String
  method    PaymentMethod
  status    PaymentStatus @default(PAID)
  amount    Decimal       @db.Decimal(12, 2)
  reference String?
  paidAt    DateTime      @default(now())
  createdAt DateTime      @default(now())

  session TableSession? @relation(fields: [sessionId], references: [id])
  user    User          @relation(fields: [userId], references: [id])

  @@index([sessionId])
  @@index([paidAt])
}
